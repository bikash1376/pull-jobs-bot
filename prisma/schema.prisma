generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String           @id @default(uuid())
  telegramChatId    String           @unique
  firstName         String?
  lastName          String?
  email             String?
  phone             String?
  location          String?
  wantsRemote       Boolean?
  currentCtc        String?
  expectedCtc       String?
  targetRole        String?
  currentTitle      String?
  experienceSummary String?
  skills            String[]
  resumeUrl         String?
  linkedInUrl       String?
  portfolioUrl      String?
  targetCategory    String?          @default("software-development")
  pendingApplyJobId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  applications      ApplicationLog[]
}

model ProcessedTelegramUpdate {
  updateId  BigInt   @id
  createdAt DateTime @default(now())
}

model ApplicationLog {
  id          String            @id @default(uuid())
  userId      String
  jobId       String
  companyName String
  jobTitle    String
  resumeUrl   String?
  status      ApplicationStatus @default(MATCHED)
  errorMessage String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id])
}

enum ApplicationStatus {
  MATCHED
  RESUME_GENERATED
  APPLYING
  APPLIED
  FAILED
}
